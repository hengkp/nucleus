# Service accounts for the auth + drive-password subsystems. These are NEW service identities
# (not a rotation of any user password). Generate real passwords and apply:
#
#   APPHUB_RO_PW=$(slappasswd -s "$(openssl rand -base64 24)")        # save the cleartext for Authelia .env
#   PWSYNC_PW=$(slappasswd   -s "$(openssl rand -base64 24)")          # save the cleartext for the backend .env
#   sed -e "s|{APPHUB_RO_SSHA}|$APPHUB_RO_PW|" -e "s|{PWSYNC_SSHA}|$PWSYNC_PW|" \
#       20-service-accounts.ldif.example | ldapadd -x -D "cn=admin,dc=siriraj,dc=local" -W
#
# Do NOT commit the filled-in file (it contains the hashed secrets).

# Read-only bind for Authelia (find users) and SSSD/Samba search.
dn: cn=apphub-ro,dc=siriraj,dc=local
objectClass: simpleSecurityObject
objectClass: organizationalRole
cn: apphub-ro
description: AppHub read-only LDAP bind
userPassword: {APPHUB_RO_SSHA}

# Write-capable bind used ONLY to set sambaNTPassword during the self-service drive-password
# flow. Grant it write to sambaNTPassword/sambaSamAccount attrs via an olcAccess rule (see
# README) — least privilege, not a full admin.
dn: cn=samba-pwsync,dc=siriraj,dc=local
objectClass: simpleSecurityObject
objectClass: organizationalRole
cn: samba-pwsync
description: AppHub Samba NT-hash writer (drive-password self-service)
userPassword: {PWSYNC_SSHA}
