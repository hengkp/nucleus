# Copy to .env on node1. Generate secrets with: `openssl rand -hex 32` (or `authelia crypto rand --length 64`).
# Do NOT commit the real .env.

# LDAP read-only bind password (cn=apphub-ro,dc=siriraj,dc=local).
AUTHELIA_AUTHENTICATION_BACKEND_LDAP_PASSWORD=

# Authelia internal secrets (each a long random string).
AUTHELIA_SESSION_SECRET=
AUTHELIA_STORAGE_ENCRYPTION_KEY=
AUTHELIA_IDENTITY_VALIDATION_RESET_PASSWORD_JWT_SECRET=

# Must equal APPHUB_PROXY_SECRET in the AppHub backend .env, and the value substituted for
# __APPHUB_PROXY_SECRET__ in nginx-apphub.conf. This is the shared edge->backend secret.
# (kept here only as a reminder; nginx holds the actual value)
# APPHUB_PROXY_SECRET=
