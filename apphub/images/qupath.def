Bootstrap: docker
From: ubuntu:22.04

# QuPath 0.7.0 as a browser app: a minimal TigerVNC X server + openbox + noVNC, so the
# JavaFX desktop GUI streams to the browser on $PORT. Runs as the requesting user under
# apptainer --containall; the per-instance vhost is Authelia-gated, so VNC needs no password.

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends \
        tigervnc-standalone-server tigervnc-common openbox \
        novnc websockify python3 \
        ca-certificates wget xz-utils dbus-x11 \
        libgtk-3-0 libgl1 libgl1-mesa-dri libglu1-mesa libegl1 \
        libxtst6 libxi6 libxrender1 libxext6 libxxf86vm1 libxrandr2 libxcursor1 libxinerama1 libxslt1.1 \
        libfreetype6 fontconfig fonts-dejavu-core

    # QuPath 0.7.0
    cd /opt
    wget -q https://github.com/qupath/qupath/releases/download/v0.7.0/QuPath-v0.7.0-Linux.tar.xz -O qupath.tar.xz
    tar -xJf qupath.tar.xz
    rm -f qupath.tar.xz
    QP="$(find /opt -type f -path '*/bin/QuPath' | head -1)"
    chmod +x "$QP"
    ln -sf "$QP" /usr/local/bin/QuPath

    # noVNC landing page -> auto-connect to the desktop, scaled to the browser window.
    printf '%s\n' '<!doctype html><meta http-equiv="refresh" content="0; url=vnc.html?autoconnect=true&reconnect=true&resize=scale&path=websockify">' > /usr/share/novnc/index.html

    # Launch script: VNC X server + window manager + QuPath + noVNC websocket proxy on $PORT.
    cat > /usr/local/bin/start-qupath.sh <<'EOS'
#!/bin/bash
set -e
PORT="${PORT:?PORT required}"
export HOME="${HOME:-/tmp}"
export DISPLAY=:1
export _JAVA_OPTIONS="-Dprism.order=sw"
mkdir -p /tmp/.X11-unix 2>/dev/null || true
Xvnc :1 -geometry "${QP_GEOMETRY:-1600x900}" -depth 24 -SecurityTypes None -localhost yes -rfbport 5901 -AlwaysShared >/tmp/xvnc.log 2>&1 &
for i in $(seq 1 60); do [ -S /tmp/.X11-unix/X1 ] && break; sleep 0.25; done
openbox >/tmp/openbox.log 2>&1 &
/usr/local/bin/QuPath >/tmp/qupath.log 2>&1 &
exec websockify --web=/usr/share/novnc "0.0.0.0:${PORT}" localhost:5901
EOS
    chmod +x /usr/local/bin/start-qupath.sh

    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    export DISPLAY=:1
