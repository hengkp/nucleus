Bootstrap: docker
From: ubuntu:22.04

# QuPath 0.7.0 as a browser app, served via KasmVNC (modern web VNC: WebP/H.264 encoding +
# better input than plain noVNC, for smoother whole-slide panning on these GPU-less nodes).
# The image just INSTALLS the stack; the apphub runner orchestrates startup (HTTP, no-auth,
# port = the app port) so it can be tuned without a rebuild. Runs as the user under --containall.

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends \
        ca-certificates wget xz-utils openbox dbus-x11 procps \
        libgtk-3-0 libgl1 libgl1-mesa-dri libglu1-mesa libegl1 \
        libxtst6 libxi6 libxrender1 libxext6 libxxf86vm1 libxrandr2 libxcursor1 libxinerama1 libxslt1.1 libxfont2 \
        libfreetype6 fontconfig fonts-dejavu-core ssl-cert

    # KasmVNC 1.4.0 (jammy)
    cd /tmp
    wget -q https://github.com/kasmtech/KasmVNC/releases/download/v1.4.0/kasmvncserver_jammy_1.4.0_amd64.deb -O kasmvnc.deb
    apt-get install -y --no-install-recommends ./kasmvnc.deb
    rm -f kasmvnc.deb

    # QuPath 0.7.0
    cd /opt
    wget -q https://github.com/qupath/qupath/releases/download/v0.7.0/QuPath-v0.7.0-Linux.tar.xz -O qupath.tar.xz
    tar -xJf qupath.tar.xz
    rm -f qupath.tar.xz
    QP="$(find /opt -type f -path '*/bin/QuPath' | head -1)"
    chmod +x "$QP"
    ln -sf "$QP" /usr/local/bin/QuPath

    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    export DISPLAY=:1
