Bootstrap: docker
From: ubuntu:22.04

# QuPath 0.7.0 as a browser app, served via KasmVNC (modern web VNC: WebP/H.264 encoding +
# better input than plain noVNC, for smoother whole-slide panning on these GPU-less nodes).
# The image just INSTALLS the stack; the apphub runner orchestrates startup (HTTP, no-auth,
# port = the app port) so it can be tuned without a rebuild. Runs as the user under --containall.

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends \
        ca-certificates wget xz-utils openbox dbus-x11 procps \
        wmctrl x11-utils xdotool \
        libgtk-3-0 libgl1 libgl1-mesa-dri libglu1-mesa libegl1 \
        libxtst6 libxi6 libxrender1 libxext6 libxxf86vm1 libxrandr2 libxcursor1 libxinerama1 libxslt1.1 libxfont2 \
        libfreetype6 fontconfig fonts-dejavu-core ssl-cert

    # KasmVNC 1.4.0 (jammy)
    cd /tmp
    wget -q https://github.com/kasmtech/KasmVNC/releases/download/v1.4.0/kasmvncserver_jammy_1.4.0_amd64.deb -O kasmvnc.deb
    apt-get install -y --no-install-recommends ./kasmvnc.deb
    rm -f kasmvnc.deb

    # QuPath 0.7.0
    cd /opt
    wget -q https://github.com/qupath/qupath/releases/download/v0.7.0/QuPath-v0.7.0-Linux.tar.xz -O qupath.tar.xz
    tar -xJf qupath.tar.xz
    rm -f qupath.tar.xz
    QP="$(find /opt -type f -path '*/bin/QuPath' | head -1)"
    chmod +x "$QP"
    ln -sf "$QP" /usr/local/bin/QuPath

    # Window helper: under KasmVNC's dynamic resize, QuPath sizes its main window and centres its
    # dialogs for the framebuffer size at launch. When the desktop is later resized to the browser
    # window, an already-open dialog (e.g. the startup licence "Notice") can land partly off-screen
    # with its buttons out of frame. This daemon acts ONLY when the desktop size changes: it
    # re-centres any dialog that is now off-screen (accounting for the WM frame) and pins/maximizes
    # the main window so the menus stay reachable. Between resizes it stays completely idle, so it
    # never fights the user moving or interacting with a dialog.
    cat > /usr/local/bin/qupath-window-fit.sh <<'WFEOF'
#!/bin/bash
export DISPLAY="${DISPLAY:-:1}"
FW=6; FT=42   # openbox frame: side border + title-bar height (approx)
is_dialog() { xprop -id "$1" WM_TRANSIENT_FOR 2>/dev/null | grep -q '0x[0-9a-fA-F]'; }
prev=""
while sleep 1; do
  read W H < <(wmctrl -d 2>/dev/null | awk 'NR==1{for(i=1;i<=NF;i++) if($i=="DG:"){split($(i+1),b,"x"); print b[1],b[2]}}')
  [ -z "$W" ] && continue
  cur="${W}x${H}"
  [ "$cur" = "$prev" ] && continue          # idle unless the desktop size actually changed
  prev="$cur"
  while read -r id x y w h; do
    [ -z "$id" ] && continue
    if is_dialog "$id"; then
      if [ "$x" -lt 0 ] || [ "$y" -lt 0 ] || [ $((x+w)) -gt "$W" ] || [ $((y+h)) -gt "$H" ]; then
        fw=$((w+FW)); fh=$((h+FT))
        fx=$(((W-fw)/2)); mfx=$((W-fw)); [ "$mfx" -lt 0 ] && mfx=0; [ "$fx" -lt 0 ] && fx=0; [ "$fx" -gt "$mfx" ] && fx=$mfx
        fy=$(((H-fh)/2)); mfy=$((H-fh)); [ "$mfy" -lt 0 ] && mfy=0; [ "$fy" -lt 0 ] && fy=0; [ "$fy" -gt "$mfy" ] && fy=$mfy
        xdotool windowmove "$id" "$fx" "$fy" 2>/dev/null
      fi
    else
      wmctrl -i -r "$id" -b add,maximized_vert,maximized_horz 2>/dev/null
      { [ "$w" -gt "$W" ] || [ "$h" -gt "$H" ]; } && xdotool windowmove "$id" 0 0 2>/dev/null
    fi
  done < <(wmctrl -lG 2>/dev/null | awk '{print $1,$3,$4,$5,$6}')
done
WFEOF
    chmod +x /usr/local/bin/qupath-window-fit.sh

    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    export DISPLAY=:1
