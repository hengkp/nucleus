// AppHub-managed Nextflow config for the in-cluster pipeline launcher.
//
// MVP model: the whole pipeline runs INSIDE the driver's SLURM allocation (executor 'local'),
// using Singularity for each process container. SLURM cgroups bound the driver job to the
// CPUs/memory it was granted, so the local executor self-limits to that allocation.
//
// To scale tasks out as separate SLURM jobs later, switch process.executor to 'slurm' and add
// a queue/clusterOptions mapping (the cluster has partitions: small*, large, UNLIMITED).

singularity {
    enabled    = true
    autoMounts = true
}

process {
    executor      = 'local'
    errorStrategy = { task.exitStatus in [104,134,137,139,143,247] && task.attempt <= 2 ? 'retry' : 'finish' }
    maxRetries    = 2
}

executor {
    queueSize = 50
}

cleanup = false
