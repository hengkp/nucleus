{
  "schemaVersion": 2,
  "templates": [
    {
      "id": "jupyterlab",
      "name": "JupyterLab",
      "category": "Notebook",
      "description": "Interactive notebooks. Shared lab envs appear as kernels by their name (python3, nextflow, ...), your own as <env> (mine). Manage your own from the terminal: apphub-conda new|list|add|rm",
      "icon": "terminal-box-line",
      "image": "jupyterlab.sif",
      "preinstalled": ["Python 3.11", "numpy", "pandas", "scanpy", "ipywidgets", "conda/mamba"],
      "defaults": { "cpus": 2, "memoryMb": 8192, "timeMinutes": 480 },
      "limits": { "maxCpus": 64, "maxMemoryMb": 262144, "maxTimeMinutes": 4320 },
      "enabled": true
    },
    {
      "id": "rstudio",
      "name": "RStudio",
      "category": "Notebook",
      "description": "RStudio session for R analysis and package work.",
      "icon": "bar-chart-box-line",
