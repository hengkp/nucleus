# Copy to .env (loaded by config.js) for local/prod.

# --- Listen ---
# A number = TCP port (dev); a path = unix socket (prod, fronted by nginx).
APPHUB_LISTEN=8792
# APPHUB_LISTEN=/run/apphub/apphub.sock

# --- Auth ---
# Dev: synthesize a logged-in user, skip header trust. NEVER set in production.
APPHUB_DEV_AUTH=1
# Production: nginx/sisp-sso injects identity. The backend only trusts these headers
# when the request also carries the shared proxy secret (so a direct hit can't spoof).
APPHUB_PROXY_SECRET=
# Header names nginx sets (defaults shown).
APPHUB_HEADER_USER=x-remote-user
APPHUB_HEADER_GROUPS=x-remote-groups

# --- SLURM ---
# mock = in-process fake scheduler (no cluster). slurm = shell out to sbatch/squeue/scancel.
APPHUB_SLURM_MODE=mock
# Sudo wrapper that submits a job AS the requesting user (fail-closed). Prod only.
APPHUB_SBATCH_WRAPPER=/opt/sisp-apphub/bin/apphub-sbatch-as-user.sh

# --- Storage ---
# Set to use Postgres (prod). Unset = in-memory + JSON file (dev).
# DATABASE_URL=postgres://apphub:secret@127.0.0.1:5432/apphub
APPHUB_STATE_FILE=./.data/state.json

# --- Routing ---
# Where the nginx route map is written, and the (sudo) command to reload nginx.
APPHUB_ROUTES_MAP=./.data/routes.map
APPHUB_NGINX_RELOAD=
# Public app domain (Q1 resolved): two-label per-instance hosts under this wildcard.
APPHUB_APP_DOMAIN=app.sisp.com

# Reserved local accounts that may never own a user job (defense in depth; the wrapper
# also enforces uid>=10000).
APPHUB_RESERVED_USERS=root,nodeadmin,admin,daemon,bin,sys,slurm,postgres,nobody
