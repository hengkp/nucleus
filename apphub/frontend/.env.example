# Copy to .env.local for local dev.

# Use the in-browser mock API (no backend needed). Default: on for dev.
VITE_USE_MOCK=1

# When VITE_USE_MOCK=0, the SPA calls same-origin /api. To proxy to a local backend:
# VITE_API_PROXY=http://127.0.0.1:8792

# Read-path safety valve (ADR-006). When OFF (default), instance polling is a calm
# 30s/60s so the frontend can never pace the SLURM reconcile loop and recreate the
# original concurrency hang. Only set to 1 once the backend ships the cached,
# non-reconciling GET /api/apps + single-flight reconcile.
VITE_APPS_READ_IS_CHEAP=0

# Where the nginx auth gateway sends unauthenticated users (full-page redirect).
VITE_GATEWAY_LOGIN_URL=/auth/login
VITE_GATEWAY_LOGOUT_URL=/auth/logout
