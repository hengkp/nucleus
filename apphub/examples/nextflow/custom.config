// Example custom Nextflow config to UPLOAD at launch (Pipelines -> Profiles & custom config).
// It layers on top of the lab-managed config, so you can override resources, add params, etc.
process {
    withName: 'FASTQC'   { cpus = 4 }
    withName: '.*:STAR.*' { cpus = 12; memory = '48 GB' }
}
params {
    // e.g. skip steps for a faster run:
    // skip_dupradar = true
}
